{
  "name": "image-gen",
  "version": "1.0.0",
  "status": "experimental",
  "owner": "core-team",
  "description": "AI image generation for logos, mockups, and assets",
  "requiresAuth": true,
  "supportsJobs": false,
  "supportsStreaming": false,
  "testLevel": "unit",
  "resilience": {
    "retry": false,
    "timeout": 30000,
    "circuitBreaker": false
  },
  "security": {
    "scope": "write",
    "dangerousCombinations": [
      "write"
    ],
    "requiresApproval": false
  },
  "performance": {
    "avgResponseTimeMs": 500,
    "maxConcurrent": 10
  },
  "documentation": {
    "readme": true,
    "examples": false,
    "apiReference": false
  },
  "dependencies": [],
  "envVars": [
    {
      "name": "OPENAI_API_KEY",
      "required": false,
      "description": "OpenAI API key for DALL-E image generation"
    },
    {
      "name": "STABILITY_API_KEY",
      "required": false,
      "description": "Stability AI API key for image generation"
    }
  ]
}

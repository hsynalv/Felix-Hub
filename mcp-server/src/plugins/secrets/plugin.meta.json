{
  "name": "secrets",
  "version": "1.0.0",
  "status": "beta",
  "owner": "core-team",
  "description": "secrets plugin",
  "requiresAuth": true,
  "supportsJobs": false,
  "supportsStreaming": false,
  "testLevel": "unit",
  "resilience": {
    "retry": false,
    "timeout": 30000,
    "circuitBreaker": false
  },
  "security": {
    "scope": "write",
    "dangerousCombinations": [
      "write"
    ],
    "requiresApproval": [
      "write"
    ],
    "riskLevel": "medium",
    "capabilities": [
      "write"
    ]
  },
  "performance": {
    "avgResponseTimeMs": 500,
    "maxConcurrent": 10
  },
  "documentation": {
    "readme": true,
    "examples": false,
    "apiReference": true
  },
  "dependencies": [],
  "envVars": [
    {
      "name": "HUB_SETTINGS_MASTER_KEY",
      "required": false,
      "description": "Master key for encrypted secret storage"
    }
  ]
}

{
  "name": "slack",
  "version": "1.0.0",
  "status": "experimental",
  "owner": "core-team",
  "description": "Slack team communication and bot integration",
  "requiresAuth": true,
  "supportsJobs": false,
  "supportsStreaming": false,
  "testLevel": "unit",
  "resilience": {
    "retry": false,
    "timeout": 30000,
    "circuitBreaker": false
  },
  "security": {
    "scope": "write",
    "dangerousCombinations": [
      "write"
    ],
    "requiresApproval": [
      "write"
    ],
    "riskLevel": "medium",
    "capabilities": [
      "write",
      "network"
    ]
  },
  "performance": {
    "avgResponseTimeMs": 500,
    "maxConcurrent": 10
  },
  "documentation": {
    "readme": true,
    "examples": false,
    "apiReference": false
  },
  "dependencies": [],
  "envVars": [
    {
      "name": "SLACK_BOT_TOKEN",
      "required": true,
      "description": "Slack bot OAuth token"
    }
  ]
}

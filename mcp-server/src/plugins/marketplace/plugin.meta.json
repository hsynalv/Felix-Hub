{
  "name": "marketplace",
  "version": "1.0.0",
  "status": "experimental",
  "owner": "core-team",
  "description": "Community plugin discovery and installation from npm",
  "requiresAuth": true,
  "supportsJobs": false,
  "supportsStreaming": false,
  "testLevel": "unit",
  "resilience": {
    "retry": false,
    "timeout": 30000,
    "circuitBreaker": false
  },
  "security": {
    "scope": "write",
    "dangerousCombinations": [
      "write"
    ],
    "requiresApproval": false
  },
  "performance": {
    "avgResponseTimeMs": 500,
    "maxConcurrent": 10
  },
  "documentation": {
    "readme": true,
    "examples": false,
    "apiReference": false
  },
  "dependencies": [],
  "envVars": [
    {
      "name": "ENABLE_MARKETPLACE",
      "required": false,
      "description": "Enable marketplace install/update routes"
    }
  ]
}

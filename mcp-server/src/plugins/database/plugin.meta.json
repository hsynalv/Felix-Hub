{
  "name": "database",
  "version": "1.0.0",
  "status": "beta",
  "owner": "core-team",
  "description": "MSSQL, PostgreSQL ve MongoDB ile veritabanı işlemleri",
  "requiresAuth": true,
  "supportsJobs": false,
  "supportsStreaming": false,
  "testLevel": "unit",
  "resilience": {
    "retry": false,
    "timeout": 30000,
    "circuitBreaker": false
  },
  "security": {
    "scope": "write",
    "dangerousCombinations": [
      "write"
    ],
    "requiresApproval": [
      "write",
      "destructive"
    ],
    "riskLevel": "medium",
    "capabilities": [
      "write"
    ]
  },
  "performance": {
    "avgResponseTimeMs": 500,
    "maxConcurrent": 10
  },
  "documentation": {
    "readme": true,
    "examples": false,
    "apiReference": true
  },
  "dependencies": [],
  "envVars": [
    {
      "name": "DATABASE_URL",
      "required": false,
      "description": "Default database connection URL"
    },
    {
      "name": "MSSQL_CONNECTION_STRING",
      "required": false,
      "description": "MSSQL connection string"
    }
  ]
}

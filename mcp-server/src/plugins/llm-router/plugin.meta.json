{
  "name": "llm-router",
  "version": "1.1.0",
  "status": "stable",
  "owner": "platform-team",
  "description": "Multi-LLM routing with cost optimization, fallback chains, and provider selection",
  "requiresAuth": false,
  "supportsJobs": false,
  "supportsStreaming": false,
  "testLevel": "unit",
  "resilience": {
    "retry": true,
    "timeout": 60000,
    "circuitBreaker": true
  },
  "security": {
    "scope": "write",
    "dangerousCombinations": [],
    "requiresApproval": [
      "write"
    ],
    "riskLevel": "medium",
    "capabilities": [
      "write",
      "network"
    ]
  },
  "performance": {
    "avgResponseTimeMs": 5000,
    "maxConcurrent": 50
  },
  "documentation": {
    "readme": true,
    "examples": true,
    "apiReference": true
  },
  "providers": [
    "openai",
    "anthropic",
    "google",
    "mistral",
    "ollama",
    "vllm"
  ],
  "supportedTasks": [
    "coding",
    "analysis",
    "documentation",
    "fast",
    "local",
    "backend_api",
    "frontend_component",
    "image_generation",
    "code_review",
    "debugging",
    "refactoring",
    "testing",
    "general",
    "complex_reasoning",
    "multilingual"
  ],
  "dependencies": [],
  "envVars": [
    {
      "name": "ANTHROPIC_API_KEY",
      "required": false,
      "description": "Anthropic API key — enables Claude Opus/Sonnet/Haiku"
    },
    {
      "name": "CHAT_LLM_MODEL",
      "required": false,
      "description": "Sohbet varsayılan modeli"
    },
    {
      "name": "CHAT_LLM_PROVIDER",
      "required": false,
      "description": "Sohbet sağlayıcısı: openai, vllm, ollama"
    },
    {
      "name": "GOOGLE_API_KEY",
      "required": false,
      "description": "Google API key — enables Gemini 2.0 Flash/Pro"
    },
    {
      "name": "LLM_KEY_MODE",
      "required": false,
      "description": "unified (tek anahtar) veya split (ayrı atama)"
    },
    {
      "name": "LLM_MAX_OUTPUT_TOKENS",
      "required": false,
      "description": "Max output tokens per request (default: 4096)"
    },
    {
      "name": "LLM_MAX_PROMPT_LENGTH",
      "required": false,
      "description": "Max prompt character length (default: 100000)"
    },
    {
      "name": "LLM_TIMEOUT_MS",
      "required": false,
      "description": "Global LLM timeout in milliseconds (default: 60000)"
    },
    {
      "name": "LLM_UNIFIED_API_KEY",
      "required": false,
      "description": "Birleşik OpenAI anahtarı (unified mod)"
    },
    {
      "name": "MISTRAL_API_KEY",
      "required": false,
      "description": "Mistral API key — enables Mistral Large/Small"
    },
    {
      "name": "OLLAMA_BASE_URL",
      "required": false,
      "description": "Ollama local server URL (default: http://localhost:11434)"
    },
    {
      "name": "OLLAMA_MODEL",
      "required": false,
      "description": "Ollama varsayılan model adı"
    },
    {
      "name": "OPENAI_API_KEY",
      "required": false,
      "description": "OpenAI API key — enables GPT-4.1, gpt-4o, o3-mini"
    },
    {
      "name": "OPENAI_CHAT_MODEL",
      "required": false,
      "description": "Default chat model id (e.g. gpt-4o-mini)"
    },
    {
      "name": "ROUTER_LLM_MODEL",
      "required": false,
      "description": "LLM router varsayılan modeli"
    },
    {
      "name": "ROUTER_LLM_PROVIDER",
      "required": false,
      "description": "LLM router sağlayıcısı"
    },
    {
      "name": "VLLM_API_KEY",
      "required": false,
      "description": "API key for the vLLM server if authentication is enabled (default: not-needed)"
    },
    {
      "name": "VLLM_BASE_URL",
      "required": false,
      "description": "vLLM or any OpenAI-compatible server URL (e.g. http://my-server:8000/v1)"
    },
    {
      "name": "VLLM_MODEL",
      "required": false,
      "description": "Default model name on the vLLM server (e.g. mistral-7b-instruct)"
    },
    {
      "name": "VLLM_MODELS",
      "required": false,
      "description": "Comma-separated list of models on the vLLM server (e.g. mistral-7b,llama-70b)"
    }
  ]
}

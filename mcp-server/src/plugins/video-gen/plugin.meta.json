{
  "name": "video-gen",
  "version": "1.0.0",
  "status": "experimental",
  "owner": "core-team",
  "description": "AI video generation for demos and content",
  "requiresAuth": true,
  "supportsJobs": false,
  "supportsStreaming": false,
  "testLevel": "unit",
  "resilience": {
    "retry": false,
    "timeout": 30000,
    "circuitBreaker": false
  },
  "security": {
    "scope": "write",
    "dangerousCombinations": [
      "write"
    ],
    "requiresApproval": [
      "write"
    ],
    "riskLevel": "medium",
    "capabilities": [
      "write",
      "network"
    ]
  },
  "performance": {
    "avgResponseTimeMs": 500,
    "maxConcurrent": 10
  },
  "documentation": {
    "readme": true,
    "examples": false,
    "apiReference": false
  },
  "dependencies": [],
  "envVars": [
    {
      "name": "HEYGEN_API_KEY",
      "required": false,
      "description": "HeyGen API key"
    },
    {
      "name": "PIKA_API_KEY",
      "required": false,
      "description": "Pika API key"
    },
    {
      "name": "RUNWAY_API_KEY",
      "required": false,
      "description": "Runway ML API key"
    }
  ]
}

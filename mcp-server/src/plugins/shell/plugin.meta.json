{
  "name": "shell",
  "version": "1.0.0",
  "status": "stable",
  "owner": "core-team",
  "description": "Production-hardened shell command execution with strict allowlist, dangerous pattern blocking, timeout enforcement, policy integration, and pluggable audit persistence",
  "requiresAuth": true,
  "supportsJobs": false,
  "supportsStreaming": true,
  "testLevel": "integration",
  "resilience": {
    "retry": true,
    "timeout": 30000,
    "circuitBreaker": false
  },
  "security": {
    "scope": "write",
    "dangerousCombinations": [
      "write"
    ],
    "requiresApproval": true
  },
  "performance": {
    "avgResponseTimeMs": 500,
    "maxConcurrent": 5
  },
  "documentation": {
    "readme": true,
    "examples": true,
    "apiReference": true
  },
  "dependencies": [],
  "envVars": [
    {
      "name": "ALLOWED_WORKING_DIRS",
      "required": false,
      "description": ""
    },
    {
      "name": "SHELL_ALLOWLIST",
      "required": false,
      "description": ""
    },
    {
      "name": "SHELL_AUDIT_FILE_PATH",
      "required": false,
      "description": ""
    },
    {
      "name": "SHELL_AUDIT_MAX_ENTRIES",
      "required": false,
      "description": ""
    },
    {
      "name": "SHELL_AUDIT_TYPE",
      "required": false,
      "description": ""
    },
    {
      "name": "SHELL_DEFAULT_TIMEOUT_MS",
      "required": false,
      "description": ""
    },
    {
      "name": "SHELL_MAX_TIMEOUT_MS",
      "required": false,
      "description": ""
    }
  ]
}

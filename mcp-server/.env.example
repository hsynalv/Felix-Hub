# MCP Hub — bootstrap only
# Plugin / entegrasyon anahtarlarını arayüzden gir: http://localhost:8787/settings → Entegrasyonlar
# Katalog: GET /settings/env-catalog (admin key)

PORT=8787
NODE_ENV=development

# Auth — boş bırakılırsa local open mode (sadece geliştirme)
HUB_READ_KEY=
HUB_WRITE_KEY=
HUB_ADMIN_KEY=

# Persistence — Settings UI + multi-chat için zorunlu
HUB_PERSISTENCE_ENABLED=true
HUB_MSSQL_URL=Server=host;Database=personal-assistant;User Id=sa;Password=secret;Encrypt=True;TrustServerCertificate=True
# 32-byte random, base64: openssl rand -base64 32
HUB_SETTINGS_MASTER_KEY=

# Felix Hub — bootstrap (.env)
# cp .env.example .env  →  değerleri doldur
# Entegrasyonlar (OpenAI, GitHub, Notion, …) → UI: /settings → Entegrasyonlar

PORT=8787
NODE_ENV=production

# Docker / reverse proxy arkasında container içi bind (compose zaten set eder)
HUB_BIND_HOST=0.0.0.0

# Tarayıcıdan erişilen tam origin(ler), virgülle ayrılmış — production zorunlu
CORS_ALLOWED_ORIGINS=https://asistan.huseyinalav.com

# ── Production security (NODE_ENV=production iken zorunlu / önerilen) ────────
WORKSPACE_STRICT_BOUNDARIES=true
WORKSPACE_REQUIRE_ID=true
CHAT_LLM_PROVIDER=openai
CHAT_LLM_MODEL=gpt-4o-mini
SHELL_MODE=safe
BRAIN_DB_SOURCE_OF_TRUTH=true
# POLICY_*_ALLOW_MISSING_EVALUATOR=true production'da yasak (startup exit)

# ── Auth (openssl rand -base64 32) ───────────────────────────────────────────
HUB_READ_KEY=change-me-read-key
HUB_WRITE_KEY=change-me-write-key
HUB_ADMIN_KEY=change-me-admin-key

# ── Persistence (MSSQL) ──────────────────────────────────────────────────────
HUB_PERSISTENCE_ENABLED=true
HUB_MSSQL_URL=Server=HOST;Database=DB;User Id=USER;Password=PASS;Encrypt=True;TrustServerCertificate=True
HUB_SETTINGS_MASTER_KEY=change-me-32-bytes-base64

# ── İlk kullanıcı (hub_users boşken bir kez) ─────────────────────────────────
HUB_SEED_EMAIL=you@example.com
HUB_SEED_PASSWORD=change-me-strong-password
HUB_SEED_DISPLAY_NAME=Your Name

# ── Opsiyonel ─────────────────────────────────────────────────────────────────
# REDIS_URL=redis://redis:6379
# AUDIT_LOG_FILE=false
# CATALOG_CACHE_DIR=./cache

# Felix Hub — .env şablonu
# Kullanım: cp .env.example .env  →  değerleri doldur  →  npm run dev
# Detaylı rehber: ../ENV-SETUP.md

# ── Sunucu ───────────────────────────────────────────────────────────────────
PORT=8787
NODE_ENV=development

# ── mcp-hub Authentication ───────────────────────────────────────────────────
# Leave all three blank ONLY with HUB_ALLOW_OPEN_HUB=true (explicit dev/local open principal).
# Otherwise tools and MCP deny anonymous access (fail-closed).
# Set at least HUB_READ_KEY to enable normal auth.
#
# Key scopes:
#   HUB_READ_KEY  → read  (catalog, search, list)
#   HUB_WRITE_KEY → read + write (apply workflows, create Notion entries)
#   HUB_ADMIN_KEY → read + write + danger (all operations)
#
# API anahtarları (openssl rand -base64 32 / 48 ile üret)
HUB_READ_KEY=
HUB_WRITE_KEY=
HUB_ADMIN_KEY=

# ── Security hardening (production) ─────────────────────────────────────────
# HUB_ALLOW_OPEN_HUB=true — without API keys, grant anonymous read+write+admin principal (NEVER in production).
#
# POLICY_ALLOW_MISSING_EVALUATOR=true — skip REST write guard + allow write tools when policy plugin is off (dev only).
# Legacy aliases: TOOL_POLICY_ALLOW_MISSING_EVALUATOR, POLICY_GUARD_ALLOW_MISSING_EVALUATOR (same effect).
#
# HUB_STRICT_WORKSPACE — non-global workspace must exist in registry. Defaults true when NODE_ENV=production.
#
# HUB_REQUIRE_TENANT_ID — require x-tenant-id / HUB_TENANT_ID for tools + discovery. Defaults true when NODE_ENV=production.
#
# HUB_POLICY_CONFIRM_QUERY_BYPASS=true — unsafe: allow ?confirmed=true on REST writes without secret header (dev only).
# HUB_POLICY_CONFIRM_SECRET — if set, REST write confirmation via X-Hub-Policy-Confirm: <secret> instead of query bypass.
#
# Align GET /plugins + openapi tool lists with MCP ListTools (default true). Set to "false" for legacy full discovery.
# DISCOVERY_FILTER_BY_PRINCIPAL=true

# ── Persistence (kapalı = bellek modu; açık = MSSQL gerekli) ─────────────────
HUB_PERSISTENCE_ENABLED=false
# HUB_MSSQL_URL=Server=HOST;Database=DB;User Id=USER;Password=PASS;Encrypt=True;TrustServerCertificate=True
# HUB_SETTINGS_MASTER_KEY=

# ── Plugin Enable/Disable ───────────────────────────────────────────────────
# Set to "false" to disable specific plugins (useful for non-n8n deployments)
ENABLE_N8N_PLUGIN=true
ENABLE_N8N_CREDENTIALS=true
ENABLE_N8N_WORKFLOWS=true

# ── İlk kullanıcı (hub_users boşken bir kez oluşturulur) ─────────────────────
HUB_SEED_EMAIL=
HUB_SEED_PASSWORD=
HUB_SEED_DISPLAY_NAME=

# ── Entegrasyonlar (alternatif: UI → /settings → Entegrasyonlar) ─────────────
# OPENAI_API_KEY=
# CHAT_LLM_PROVIDER=openai
# CHAT_LLM_MODEL=gpt-4o-mini
# GITHUB_TOKEN=
# NOTION_API_KEY=
# NOTION_ROOT_PAGE_ID=
# NOTION_PROJECTS_DB_ID=
# NOTION_TASKS_DB_ID=
# N8N_BASE_URL=http://localhost:5678
# N8N_API_KEY=
# ALLOW_N8N_WRITE=false
# REDIS_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_ALLOWED_CHAT_IDS=
# TELEGRAM_WEBHOOK_SECRET=

# ── V5 Ops — observability webhook (opsiyonel) ───────────────────────────────
# SENTRY_DSN=
# SENTRY_WEBHOOK_SECRET=
# DATADOG_WEBHOOK_SECRET=
# SLA_ESCALATION_REPO=owner/repo
# INCIDENT_DEFAULT_OWNER=on-call

# ── Desktop / sidecar (macOS, opsiyonel) ─────────────────────────────────────
# DESKTOP_OCR_REQUIRED=false
# DESKTOP_ALLOWED_APPS=Cursor,Google Chrome,Terminal,iTerm2
# DESKTOP_BLOCKED_APPS=Keychain Access,1Password,Bitwarden
# SIDECAR_PORT=9477
# SIDECAR_AUTH_TOKEN=

# ── Obsidian (opsiyonel) ─────────────────────────────────────────────────────
# OBSIDIAN_VAULT_PATH=
# OBSIDIAN_EXPORT_ENABLED=false

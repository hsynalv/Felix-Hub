{
  "name": "ai-hub",
  "version": "1.0.0",
  "description": "Felix Hub — universal tool and service bridge for AI agents",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "mcp-hub-stdio": "./bin/mcp-hub-stdio.js",
    "mcp-hub-sidecar": "./bin/sidecar-daemon.js",
    "felix-desktop": "./bin/sidecar-daemon.js"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "start:hub": "npm run ui:build && node src/index.js",
    "hub:serve": "node src/index.js",
    "hub:live": "npm run ui:build && npx --yes concurrently -n api,ui -c blue,magenta \"npm run dev\" \"npm run ui:watch\"",
    "hub:daemon": "node src/index.js",
    "pm2:start": "bash scripts/pm2-start.sh",
    "pm2:reload": "bash scripts/pm2-reload.sh",
    "pm2:stop": "pm2 stop felix-hub",
    "pm2:restart": "pm2 restart felix-hub",
    "pm2:delete": "pm2 delete felix-hub",
    "pm2:logs": "pm2 logs felix-hub --lines 150",
    "pm2:status": "pm2 status felix-hub",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f --tail=150",
    "docker:ps": "docker compose ps",
    "ui:dev": "npm run dev --prefix frontend",
    "ui:build": "npm run build --prefix frontend",
    "ui:watch": "npm run build:watch --prefix frontend",
    "dev:all": "npx --yes concurrently -n api,ui -c blue,magenta \"npm run dev\" \"npm run ui:dev\"",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "prepare": "husky",
    "test": "vitest",
    "test:run": "vitest run",
    "test:security": "vitest run tests/security",
    "test:coverage": "vitest run --coverage",
    "validate:plugins": "node scripts/validate-plugin-meta.js",
    "validate:tools": "node scripts/validate-tool-schemas.js",
    "sync:plugin-security": "node scripts/sync-plugin-security-manifest.js",
    "sync:plugin-meta-env": "node scripts/sync-plugin-meta-env.js",
    "scaffold:plugin-meta": "node scripts/scaffold-plugin-meta.js",
    "test:integration": "vitest run --config vitest.integration.config.js",
    "test:integration:stable": "vitest run --config vitest.integration.stable.config.js",
    "eval:smoke": "vitest run tests/eval/trace-regression.test.js",
    "eval:prompt": "vitest run tests/core/faz-v8-c.test.js && node -e \"import('./src/core/eval/prompt-eval.service.js').then(m=>{const r=m.runPromptEvalSuite(); console.log(JSON.stringify(r.summary)); process.exit(r.pass?0:1)}).catch(e=>{console.error(e);process.exit(1)})\"",
    "eval:prompt:llm": "vitest run tests/eval/prompt-conversation-regression.test.js",
    "prompt:import": "node scripts/prompt-importer.js",
    "eval:ci": "vitest run tests/eval/trace-regression.test.js tests/core/faz3-v4.test.js",
    "eval:run": "node bin/run-retrieval-evals.js run",
    "eval:compare": "node bin/run-retrieval-evals.js compare",
    "create-plugin": "node bin/create-plugin.js",
    "sidecar:daemon": "node bin/sidecar-daemon.js",
    "sidecar:install": "bash scripts/install-sidecar-local.sh",
    "sidecar:tunnel": "bash scripts/sidecar-tunnel-cloudflared.sh",
    "sidecar:pm2:start": "bash scripts/pm2-sidecar-start.sh",
    "sidecar:pm2:stop": "pm2 stop felix-sidecar",
    "sidecar:pm2:restart": "pm2 restart felix-sidecar",
    "sidecar:pm2:delete": "pm2 delete felix-sidecar",
    "sidecar:pm2:logs": "pm2 logs felix-sidecar --lines 150",
    "sidecar:pm2:status": "pm2 status felix-sidecar"
  },
  "keywords": [
    "ai",
    "agents",
    "automation",
    "cursor",
    "claude",
    "llm",
    "mcp",
    "github",
    "notion",
    "api"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/eslintrc": "^2.1.4",
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "vitest": "^1.6.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1001.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@nlpjs/lang-en": "4.26.1",
    "@nlpjs/lang-tr": "4.26.1",
    "@nlpjs/nlp": "4.27.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "googleapis": "^171.4.0",
    "imapflow": "^1.4.3",
    "ioredis": "^5.10.0",
    "js-yaml": "^4.1.1",
    "mongodb": "^7.1.0",
    "morgan": "^1.10.0",
    "mssql": "^12.2.0",
    "n8n-core": "^1.122.16",
    "n8n-nodes-base": "^1.121.15",
    "n8n-workflow": "^1.120.9",
    "nodemailer": "^8.0.1",
    "openai": "^6.27.0",
    "pdf-parse": "^1.1.1",
    "pdf2pic": "^3.2.0",
    "pg": "^8.19.0",
    "playwright": "^1.61.1",
    "tesseract.js": "^5.1.0",
    "zod": "^3.23.8"
  }
}
